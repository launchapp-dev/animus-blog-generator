# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# .env is gitignored — your keys stay local.
# ──────────────────────────────────────────────────────────────

# Search & Research (at least one is required)
EXA_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# Google (optional — enables Search Console + Maps integrations)
GOOGLE_MAPS_API_KEY=
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=

# Image Generation (optional — enables featured image generation)
REPLICATE_API_TOKEN=

# LLM Citation Tracking (optional — enables Perplexity-based AI SEO analysis)
PERPLEXITY_API_KEY=

# ──────────────────────────────────────────────────────────────
# Discovery flow (transcript-driven idea pipeline)
# ──────────────────────────────────────────────────────────────

# Audio Transcript Source (Krisp; portable to Granola)
KRISP_API_KEY=

# Linear (via animus-subject-linear plugin)
LINEAR_API_TOKEN=
LINEAR_TEAM_ID=                        # Linear team UUID
LINEAR_DISCOVERY_PROJECT_ID=           # Linear project UUID for blog ideas
LINEAR_STATUS_MAP=                     # Optional JSON override; see plugin README
LINEAR_FINALIZE_TRANSITION=            # Optional: set to "done" to auto-complete on finalize

# Approval watcher (scripts/approval-watch.sh)
# The Linear plugin (v0.1.9) scopes `subject list` to the configured
# project SERVER-SIDE (build_issue_filter), but does not echo project_id per
# subject. Set this so the watcher trusts that backend scoping rather than
# failing closed. Safe ONLY because the plugin now applies the project filter.
APPROVAL_WATCH_ASSUME_BACKEND_PROJECT_SCOPED=1
# The plugin's list filter reads the project from the subjects config in
# .animus/workflows/custom.yaml (config.project_id). If your build needs an env
# fallback instead, set LINEAR_PROJECT_ID to the same value:
# LINEAR_PROJECT_ID=                    # = LINEAR_DISCOVERY_PROJECT_ID

# Content Library MCP
CONTENT_LIBRARY_URL=
CONTENT_LIBRARY_TOKEN=

# Subject backends — route sqlite onto a dedicated local kind so it does not
# collide with markdown's 'task'. Read by the sqlite plugin at daemon start.
ANIMUS_SQLITE_KINDS=blogtask
