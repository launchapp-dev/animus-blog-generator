# Secrets
.env

# Animus runtime state (.ao/ was renamed to .animus/ in Animus v0.4)
.animus/logs/
.animus/sync.json
.animus/queue.lock
.animus/config.json
.animus/subjects/
.animus/requirements/
.animus/skills/.migrated-from-ao
.animus/workflows/*.bak
.animus/state/

# Bundled Animus workflows are scaffolded into .animus/workflows/ by
# `animus init`; they aren't project state. The project-specific blog
# pipeline lives in .animus/workflows/custom.yaml, which IS tracked.
.animus/workflows/hotfix-workflow.yaml
.animus/workflows/research-workflow.yaml
.animus/workflows/standard-workflow.yaml

